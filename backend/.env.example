# Firebase Admin SDK service account JSON path
FIREBASE_CREDENTIALS_PATH=./serviceAccountKey.json

# Firebase project config (for storage bucket)
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# Whisper model size: tiny | base | small | medium | large
WHISPER_MODEL=base

# Summarization model: facebook/bart-large-cnn | t5-base
SUMMARIZER_MODEL=facebook/bart-large-cnn

# Set to true to use T5-small for summarization instead of extractive method
USE_AI_SUMMARIZER=false

# ── AI / LLM Features (optional) ─────────────────────────────────────────────
# OpenAI API key — enables LLM-powered summarization & quiz generation
OPENAI_API_KEY=

# Google Gemini API key — enables multimodal quiz generation (text + image)
# Get yours at: aistudio.google.com/app/apikey
GEMINI_API_KEY=
