rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Only signed-in users may read or write anything.
    // The backend (Admin SDK) bypasses these rules entirely, so writes from
    // Python are always allowed regardless of what is written here.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
